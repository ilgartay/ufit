# PostgreSQL bağlantısı (docker-compose ile eşleşmeli)
DATABASE_URL="postgresql://spor:spor_dev_pw@localhost:5432/spor_salonu?schema=public"

# JWT imzalama anahtarı (üretimde mutlaka değiştirin)
JWT_SECRET="degistir-bu-uzun-rastgele-bir-jwt-secret-olmali"

# QR entry token HMAC anahtarı (üretimde mutlaka değiştirin)
QR_SECRET="degistir-bu-uzun-rastgele-bir-qr-secret-olmali"

# Giriş QR token ömrü (saniye)
QR_TOKEN_TTL_SECONDS="60"

# İlk admin personel hesabı (seed scripti kullanır)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_ADMIN_FULLNAME="Sistem Yöneticisi"

# --- SMS sağlayıcı ---
# console = gerçek SMS göndermez, sunucu loguna yazar (varsayılan, demo için)
# netgsm  = Netgsm HTTP API (Türkiye)
# twilio  = Twilio REST API
SMS_PROVIDER="console"

# Netgsm (SMS_PROVIDER=netgsm ise)
NETGSM_USERCODE=""
NETGSM_PASSWORD=""
NETGSM_MSGHEADER=""

# Twilio (SMS_PROVIDER=twilio ise)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
